+# ── RunResult (P154/MOL-509) ───────────────────────────────────────────────
+
+# P154/MOL-509 review (#176 fix-pass-1): closed `final_status` vocabulary
+# promoted to a `Literal` so mypy catches typos at construction sites and
+# future callers (daemon P156 / cron-fallback P158) get IDE completions.
+# Mirrors the P153 `PhaseName` precedent in the same file.
+FinalStatus = Literal[
+    "succeeded",                       # phases 1-4 passed + PR merged
+    "incomplete",                      # phase abort / budget exhausted / REVISE-RETHINK
+    "failed",                          # Phase 1 (planner) failed
+    "skipped_recently_running",        # state shows running < 60min ago
+    "skipped_max_attempts",            # attempt_count >= 3
+    "skipped_succeeded_in_progress",   # loud-skip: succeeded but Jira still In Progress
+    "skipped_progressed",              # silent-skip: succeeded + progressed past In Progress
+    "dry_run",                         # DRY_RUN short-circuit
+]
+
+
+@dataclass(frozen=True)
+class RunResult:
+    """Outcome of a single symphony-bridge ticket execution.
+
+    P154/MOL-509 — returned by `run_one(key)`. Both the cron driver
+    (`main` loop) and the future daemon (P156) consume this to update
+    their respective queues.
+
+    `dispatched=False` means the ticket was skipped (max attempts,
+    recently-running, succeeded-and-progressed, etc.) — the caller
+    should not increment a "dispatched this tick" counter.
+
+    Closed `final_status` vocabulary lives in the `FinalStatus` Literal
+    just above; the docstring there enumerates each value's meaning.
+
+    `pr_num` is `str | None` (not `int | None`): `phase_builder` yields
+    the PR number from `re.search(r"PR_NUM=(\\d+)", output).group(1)`,
+    so the upstream type is `str`. `phase_reviewer(..., pr_num: str)`
+    confirms.
+
+    `__post_init__` enforces three load-bearing invariants at runtime
+    (Literal validation isn't enforced by Python itself; mypy catches it
+    statically, this guards the daemon/cron callers in production too):
+
+    1. ``final_status`` is a member of the closed ``FinalStatus`` vocab.
+    2. ``dispatched=False`` implies a ``skipped_*`` final_status.
+    3. ``final_status='succeeded'`` implies ``pr_state='merged'`` and
+       ``pr_num is not None`` (a succeeded dispatch always merged a PR).
+    """
+    dispatched: bool
+    final_status: FinalStatus
+    pr_num: str | None = None
+    pr_state: str | None = None
+    error: str | None = None
+    detail_line: str | None = None
+
+    def __post_init__(self):
+        valid = get_args(FinalStatus)
+        if self.final_status not in valid:
+            raise ValueError(
+                f"final_status={self.final_status!r} not in FinalStatus "
+                f"vocabulary {valid}"
+            )
+        if not self.dispatched and not self.final_status.startswith("skipped_"):
+            raise ValueError(
+                f"dispatched=False requires a skipped_* final_status; "
+                f"got {self.final_status!r}"
+            )
+        if self.final_status == "succeeded":
+            if self.pr_state != "merged":
+                raise ValueError(
+                    f"final_status='succeeded' requires pr_state='merged', "
+                    f"got {self.pr_state!r}"
+                )
+            if self.pr_num is None:
+                raise ValueError(
+                    "final_status='succeeded' requires pr_num to be set"
+                )
+
 
 # ── BudgetTracker (P153/MOL-506) ───────────────────────────────────────────
 
@@ -1458,6 +1537,276 @@
