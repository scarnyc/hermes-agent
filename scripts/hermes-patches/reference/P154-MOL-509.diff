+def run_one(key: str, *, dry_run: bool = False) -> RunResult:
+    """Execute the symphony pipeline for a single ticket.
+
+    P154/MOL-509 — extracted from `main()` to give the future daemon
+    (P156) and the cron-fallback path (P158) a shared primitive.
+
+    Reads state from disk (initializes if missing), applies skip-logic,
+    then runs the 4-phase dispatch + gh pr merge. Returns a RunResult
+    describing the outcome. Caller (cron `main()` or daemon loop) is
+    responsible for the per-tick cap and the summary line.
+
+    Pre-flight (PAUSED, DRY_RUN detection, SIGKILL sweep, preflight
+    probe + health gate, Jira JQL query) stays in the caller — it's a
+    pre-tick concern, not a per-ticket concern.
+    """
+    # ── Skip-logic ──────────────────────────────────────────────────
+    state = read_state(key)
+    if state:
+        last_status = state.get("last_status", "")
+        attempt_count = state.get("attempt_count", 0)
+        last_attempt_ts = state.get("last_attempt_ts")
+
+        if last_status == "running" and last_attempt_ts:
+            try:
+                last_dt = datetime.fromisoformat(last_attempt_ts)
+                age = (datetime.now(timezone.utc) - last_dt).total_seconds()
+                if age < 3600:
+                    _log(f"{key}: recently running ({age:.0f}s ago), skipping")
+                    return RunResult(dispatched=False,
+                                     final_status="skipped_recently_running")
+            except (ValueError, TypeError):
+                pass
+
+        if attempt_count >= 3:
+            _log(f"{key}: max attempts ({attempt_count}), skipping")
+            print(f"⚠️ {key}: symphony-bridge max attempts exceeded "
+                  f"— manual intervention needed")
+            return RunResult(dispatched=False,
+                             final_status="skipped_max_attempts")
+
+        if last_status == "succeeded":
+            ok, body, _ = _run_jira(["jira", "issue", "view", key, "--plain"])
+            if ok and "In Progress" in body:
+                _log(f"{key}: loud-skip — succeeded but still In Progress")
+                print(f"⚠️ {key}: marked succeeded but still In Progress "
+                      f"in Jira — verify PR landed + transition manually")
+                return RunResult(dispatched=False,
+                                 final_status="skipped_succeeded_in_progress")
+            elif ok:
+                _log(f"{key}: silent-skip — progressed past In Progress")
+                return RunResult(dispatched=False,
+                                 final_status="skipped_progressed")
+
+    # First time seeing this key — initialize state
+    if not state:
+        state = {
+            "key": key,
+            "first_seen": _now_et_iso(),
+            "last_attempt_ts": None,
+            "attempt_count": 0,
+            "last_status": "unstarted",
+        }
+
+    # DRY_RUN short-circuit — no state mutation, no dispatch
+    if dry_run:
+        _log(f"{key}: would dispatch (DRY RUN)")
+        return RunResult(dispatched=True, final_status="dry_run",
+                         detail_line=f"- Would-dispatch: {key} (DRY RUN)")
+
+    # ── LIVE dispatch ───────────────────────────────────────────────
+    state["last_status"] = "running"
+    state["last_attempt_ts"] = _now_et_iso()
+    # P148/MOL-498: stamp dispatch_start checkpoint BEFORE first phase so SIGKILL
+    # recovery on next tick can name the phase that died.
+    _set_checkpoint(state, "dispatch_start")
+    _safe_write_state(key, state, where="dispatch_start")
+
+    # P153/MOL-506: start the global wall-clock budget at dispatch_start.
+    # All six phase boundaries below (planner / skeptic / planner_revise /
+    # skeptic_revise / builder / reviewer) gate on tracker.can_start_phase(...)
+    # and each retry inside run_phase_with_fallback consults tracker.remaining().
+    tracker = BudgetTracker.start_now()
+    _log_event("budget_tracker_started", key=key,
+               budget_summary=tracker.to_summary())
+
+    _log(f"Dispatching {key} (attempt {state['attempt_count'] + 1})")
+    _log_event("dispatch_start", key=key,
+               attempt_count=state["attempt_count"] + 1)
+
+    # Extract repo + ticket info
+    ticket_body = get_ticket_body(key)
+    repo_path = extract_repo(ticket_body)
+    summary = get_ticket_summary(key, ticket_body)
+    _log(f"  Repo: {repo_path}")
+    _log(f"  Summary: {summary[:100]}")
+
+    # ── Phase 1: Planner ───────────────────────────────────────────
+    if not tracker.can_start_phase("planner"):  # P153/MOL-506
+        _abort_budget_exhausted(key, state, "planner", tracker)
+        return RunResult(dispatched=True, final_status="incomplete")
+    _log("── Phase 1 (Planner) ──")
+    p1 = phase_planner(key, summary, ticket_body, repo_path, tracker=tracker)
+    if not p1["ok"]:
+        state["last_status"] = "failed"
+        state["attempt_count"] += 1
+        _safe_write_state(key, state, where="planner_failed")
+        _log(f"DISPATCH FAILED: {key} Phase 1 failed: {p1.get('error')}")
+        _log_event("phase_failed", key=key, phase="planner",
+                   error=str(p1.get("error", ""))[:300], tier=p1.get("tier"))
+        return RunResult(dispatched=True, final_status="failed",
+                         error=str(p1.get("error", ""))[:300])
+
+    plan_content = p1["plan_content"]
+    _set_checkpoint(state, "planner_done")
+    _safe_write_state(key, state, where="planner_done")
+    _log_event("phase_complete", key=key, phase="planner", tier=p1.get("tier"))
+
+    # ── Phase 2: Skeptic ───────────────────────────────────────────
+    if not tracker.can_start_phase("skeptic"):  # P153/MOL-506
+        _abort_budget_exhausted(key, state, "skeptic", tracker)
+        return RunResult(dispatched=True, final_status="incomplete")
+    _log("── Phase 2 (Skeptic) ──")
+    p2 = phase_skeptic(key, repo_path, tracker=tracker)
+
+    if p2["verdict"] == "RETHINK":
+        state["last_status"] = "incomplete"
+        state["attempt_count"] += 1
+        _safe_write_state(key, state, where="skeptic_rethink")
+        _log(f"DISPATCH INCOMPLETE: {key} Phase 2 RETHINK")
+        print(f"⚠️ {key}: plan-skeptic RETHINK — plan architecturally flawed")
+        return RunResult(dispatched=True, final_status="incomplete")
+
+    if p2["verdict"] == "REVISE":
+        # P153/MOL-506: both legs of the REVISE loop are full phases —
+        # gate each independently. A REVISE-retry that can't fit Phase 1
+        # is just budget exhaustion, not a retry failure.
+        if not tracker.can_start_phase("planner_revise"):
+            _abort_budget_exhausted(key, state, "planner_revise", tracker)
+            return RunResult(dispatched=True, final_status="incomplete")
+        _log("Phase 2 REVISE — re-running Phase 1 with findings")
+        revised_body = ticket_body + f"\n\nSkeptic findings:\n{p2['output'][:2000]}"
+        p1 = phase_planner(key, summary, revised_body, repo_path, tracker=tracker)
+        if not p1["ok"]:
+            state["last_status"] = "failed"
+            state["attempt_count"] += 1
+            _safe_write_state(key, state, where="planner_revise_failed")
+            _log(f"DISPATCH FAILED: {key} Phase 1 retry failed")
+            return RunResult(dispatched=True, final_status="failed")
+
+        plan_content = p1["plan_content"]  # needed for phase_builder below
+        if not tracker.can_start_phase("skeptic_revise"):  # P153/MOL-506
+            _abort_budget_exhausted(key, state, "skeptic_revise", tracker)
+            return RunResult(dispatched=True, final_status="incomplete")
+        p2 = phase_skeptic(key, repo_path, tracker=tracker)
+        if p2["verdict"] in ("REVISE", "RETHINK", None):
+            state["last_status"] = "incomplete"
+            state["attempt_count"] += 1
+            _safe_write_state(key, state, where="skeptic_revise_failed")
+            _log(f"DISPATCH INCOMPLETE: {key} Phase 2 retry: {p2['verdict']}")
+            _log_event("phase_failed", key=key, phase="skeptic_retry",
+                       verdict=p2.get("verdict"), tier=p2.get("tier"))
+            print(f"⚠️ {key}: plan-skeptic {p2['verdict']} "
+                  f"after retry — plan needs manual revision")
+            return RunResult(dispatched=True, final_status="incomplete")
+
+    _set_checkpoint(state, "skeptic_done")
+    _safe_write_state(key, state, where="skeptic_done")
+    _log_event("phase_complete", key=key, phase="skeptic",
+               verdict=p2.get("verdict"), tier=p2.get("tier"))
+
+    # ── Phase 3: Builder ───────────────────────────────────────────
+    if not tracker.can_start_phase("builder"):  # P153/MOL-506
+        _abort_budget_exhausted(key, state, "builder", tracker)
+        return RunResult(dispatched=True, final_status="incomplete")
+    _log("── Phase 3 (Builder) ──")
+    p3 = phase_builder(key, plan_content, repo_path, tracker=tracker)
+    pr_num = p3.get("pr_num")
+
+    if not p3["ok"] or not pr_num:
+        state["last_status"] = "incomplete"
+        state["attempt_count"] += 1
+        _safe_write_state(key, state, where="builder_failed")
+        _log(f"DISPATCH INCOMPLETE: {key} Phase 3 failed or no PR")
+        _log_event("phase_failed", key=key, phase="builder",
+                   error=str(p3.get("error", ""))[:300], tier=p3.get("tier"))
+        return RunResult(dispatched=True, final_status="incomplete",
+                         error=str(p3.get("error", ""))[:300])
+
+    _set_checkpoint(state, "builder_done")
+    _safe_write_state(key, state, where="builder_done")
+    _log_event("phase_complete", key=key, phase="builder",
+               pr_num=pr_num, tier=p3.get("tier"))
+
+    # ── Phase 4: Reviewer ──────────────────────────────────────────
+    if not tracker.can_start_phase("reviewer"):  # P153/MOL-506
+        # P153/MOL-506: builder already opened a PR; record it on
+        # state so the next tick (or a manual sweep) can find + triage
+        # the un-reviewed PR instead of leaving it orphaned.
+        state["orphan_pr_num"] = pr_num
+        _abort_budget_exhausted(key, state, "reviewer", tracker)
+        return RunResult(dispatched=True, final_status="incomplete",
+                         pr_num=pr_num)
+    _log("── Phase 4 (Reviewer) ──")
+    p4 = phase_reviewer(key, pr_num, repo_path, tracker=tracker)
+
+    # ── Bash gate ──────────────────────────────────────────────────
+    if p4["gate"] == 0:
+        _log(f"Merging PR #{pr_num}")
+        try:
+            r = subprocess.run(
+                ["gh", "pr", "merge", str(pr_num), "--squash", "--delete-branch"],
+                capture_output=True, text=True, timeout=30,
+                cwd=repo_path,
+            )
+            # gh pr merge returns non-zero for branch protection,
+            # mergeability conflicts, auth failure, network 5xx,
+            # rate-limit. Capturing the exit code prevents falsely
+            # marking the state as merged when the PR is still open
+            # (which would then trip the silent-skip path next tick).
+            if r.returncode == 0:
+                pr_state = "merged"
+            else:
+                pr_state = "open"
+                _log_event("pr_merge_failed",
+                           key=key, pr_num=pr_num,
+                           exit_code=r.returncode,
+                           stderr_tail=_stderr_tail(r.stderr or ""))
+                sys.stderr.write(
+                    f"⚠️ {key}: gh pr merge #{pr_num} "
+                    f"exit {r.returncode}: {(r.stderr or '')[:200]}\n")
+                sys.stderr.flush()
+        except (OSError, subprocess.TimeoutExpired) as exc:
+            pr_state = "open"
+            _log_event("pr_merge_exception",
+                       key=key, pr_num=pr_num,
+                       exc_type=type(exc).__name__,
+                       exc=str(exc)[:200])
+            sys.stderr.write(
+                f"⚠️ {key}: gh pr merge exception: "
+                f"{type(exc).__name__}: {str(exc)[:200]}\n")
+            sys.stderr.flush()
+    else:
+        pr_state = "open"
+
+    _set_checkpoint(state, "reviewer_done")
+    _log_event("phase_complete", key=key, phase="reviewer",
+               passed=p4.get("passed"), gate=p4.get("gate"),
+               pr_state=pr_state, tier=p4.get("tier"))
+
+    # ── Update final state ─────────────────────────────────────────
+    if p4["passed"] and pr_state == "merged":
+        state["last_status"] = "succeeded"
+        # attempt_count unchanged (success)
+    else:
+        state["last_status"] = "incomplete"
+        state["attempt_count"] += 1
+
+    _safe_write_state(key, state, where="dispatch_complete")
+
+    _log(f"DISPATCH COMPLETE: {key} status={state['last_status']} "
+         f"pr_state={pr_state}")
+    _log_event("dispatch_complete", key=key,
+               final_status=state["last_status"],
+               pr_state=pr_state, pr_num=pr_num,
+               attempt_count=state["attempt_count"])
+
+    return RunResult(dispatched=True, final_status=state["last_status"],
+                     pr_num=pr_num, pr_state=pr_state)
+
