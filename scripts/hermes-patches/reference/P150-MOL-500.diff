+# P150/MOL-500: CC-native agent file loading + safe placeholder substitution.
+
+_PHASE_AGENT_CACHE: dict[str, str] = {}
+
+
+def _load_phase_agent(phase: str) -> str:
+    """P150/MOL-500: load + cache the body of a CC-native agent file from AGENTS_DIR.
+
+    Returns just the Markdown body (everything after the closing `---`).
+    Cached per process — call sites do not pay re-read cost across phases.
+
+    Raises:
+        FileNotFoundError: agent file missing.
+        RuntimeError: malformed YAML frontmatter (missing or unclosed `---`).
+    """
+    if phase in _PHASE_AGENT_CACHE:
+        return _PHASE_AGENT_CACHE[phase]
+
+    path = AGENTS_DIR / f"{phase}.md"
+    if not path.exists():
+        raise FileNotFoundError(f"phase agent file missing: {path}")
+    content = path.read_text()
+    parts = re.split(r"^---\s*$", content, maxsplit=2, flags=re.MULTILINE)
+    if len(parts) != 3:
+        raise RuntimeError(
+            f"phase agent {path} malformed: expected `---` frontmatter delimiters "
+            f"(got {len(parts)} parts, need 3)"
+        )
+    body = parts[2].lstrip()
+    _PHASE_AGENT_CACHE[phase] = body
+    return body
 
 
+def safe_format(template: str, **vars) -> str:
+    """P150/MOL-500: thin wrapper over str.format with defensive guarantees.
+
+    str.format() does NOT re-interpret brace characters in substituted VALUES,
+    so user content like a JSON object `{"required": ["x"]}` passes through
+    literally — no per-value escaping needed. The earlier "escape user content"
+    approach was wrong: it produced doubled braces (`{{...}}`) in the output.
+
+    Hard constraints (enforced by verify_patches.sh):
+      - Agent file BODY (the template) must not contain literal `{` / `}`
+        outside designated placeholder positions.
+      - Every placeholder name in the body must be a kwarg of safe_format —
+        an unsubstituted `{name}` would ship to the LLM as literal text
+        (skill_prompt_placeholder_fragility memory).
+
+    Raises KeyError loud-and-clear if the template references a placeholder
+    name that isn't in `vars`. _USER_CONTENT_FIELDS documents which kwarg
+    names carry untrusted text (for future content-validation hooks).
+    """
+    return template.format(**vars)
+
