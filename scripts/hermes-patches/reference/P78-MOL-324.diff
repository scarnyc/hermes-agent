+class TestBuildToolInventoryPrompt:
+    """Behavioral coverage for the dynamic <tool_inventory> system-prompt
+    section.  Cache-stability properties (sort discipline, byte-stable
+    output) are load-bearing because every byte change here invalidates
+    the prompt-cache prefix on gateway restart — locked here so a future
+    refactor that swaps a sorted iteration for a bare dict iteration fails
+    a test instead of silently breaking caching."""
+
+    @staticmethod
+    def _schema(name: str, description: str = "") -> dict:
+        return {"function": {"name": name, "description": description}}
+
+    def test_byte_stable_across_calls_same_input(self):
+        valid = {"web_search", "terminal"}
+        schemas = [
+            self._schema("web_search", "Tavily-backed web search."),
+            self._schema("terminal", "Run shell commands."),
+        ]
+        a = build_tool_inventory_prompt(valid_tool_names=valid, tool_schemas=schemas)
+        b = build_tool_inventory_prompt(valid_tool_names=valid, tool_schemas=schemas)
+        assert a == b
+
+    def test_byte_stable_across_dict_insertion_order(self):
+        # Different set / list iteration orders MUST produce identical bytes —
+        # without sort discipline this fails on Python's hash-randomized sets.
+        schemas = [
+            self._schema("alpha", "Alpha tool."),
+            self._schema("beta", "Beta tool."),
+            self._schema("gamma", "Gamma tool."),
+        ]
+        forward = build_tool_inventory_prompt(
+            valid_tool_names={"alpha", "beta", "gamma"},
+            tool_schemas=schemas,
+        )
+        reverse = build_tool_inventory_prompt(
+            valid_tool_names={"gamma", "beta", "alpha"},
+            tool_schemas=list(reversed(schemas)),
+        )
+        assert forward == reverse
+
+    def test_internal_denylist_excludes_member(self, monkeypatch):
