+# === P78 / MOL-324: tool inventory in system prompt ===
+# Hand-maintained one-liners keyed by MCP server name.  The upstream
+# ``mcp_servers:`` schema has no ``description:`` field, so this is the
+# interim source of truth.  Servers missing from this map fall back to the
+# first registered tool's description (truncated to 80 chars) — see the
+# ``sorted(tools)[0]`` lookup in ``build_tool_inventory_prompt`` so the
+# fallback is byte-stable across restarts.
+MCP_SERVER_PURPOSES: "dict[str, str]" = {
+    "context7": "library docs (React, Next.js, Prisma, etc.) — current versions, not training data",
+    "copilotkit": "CopilotKit + AG-UI documentation and code search for generative-UI / frontend tools",
+    "chrome-devtools": "browser automation, performance traces, Lighthouse audits, accessibility checks",
+    "markitdown": "convert PDF / DOCX / PPTX / XLSX / HTML to Markdown",
+}
+
+# Hand-maintained denylist for plumbing tools that should never appear in
+# the Built-in section.  Currently empty: the empty-description and
+# ``Internal:``-prefix heuristic in ``build_tool_inventory_prompt`` catches
+# every plumbing tool we have today.  Kept as an extension point for tools
+# the heuristic can't catch (well-described but agent-internal); add a name
+# here only after confirming the tool exists in the registry.  ``frozenset``
+# expresses immutability to prevent accidental runtime mutation.
+INTERNAL_TOOL_DENYLIST: "frozenset[str]" = frozenset()
+
+# CLI tools available through the ``terminal`` tool — not in any registry,
+# but materially how Hermes builds and tests UIs.  Static list maintained
+# alongside the canonical AGENTS.md "Library documentation & component
+# installers" section; update both when adding new CLIs.
+CLI_TOOLS_VIA_TERMINAL: "list[tuple[str, str]]" = [
+    ("shadcn", "shadcn/ui component installer (pnpm dlx shadcn@latest add <component>)"),
+    ("playwright-cli", "headed browser automation (token-light vs Playwright MCP)"),
+    ("crawl4ai-wrapper.sh", "URL → markdown extraction with SSRF guard"),
+    ("gws", "Google Workspace CLI (calendar, gmail, drive, docs)"),
+    ("jira", "Atlassian Jira CLI (issue list / view / edit, comment add)"),
+]
+
+
+def build_tool_inventory_prompt(
+    valid_tool_names: "set[str] | None" = None,
+    tool_schemas: "list[dict] | None" = None,
+) -> str:
+    """Build a ``<tool_inventory>`` block listing the agent's actual tools.
+
+    Three sections, all sorted for byte-stable output across restarts (so
+    prompt-cache prefixes survive gateway restarts):
+
+    1. ``## Built-in tools`` — non-MCP names from ``valid_tool_names``,
+       filtered through ``INTERNAL_TOOL_DENYLIST`` and the empty / Internal:
+       description heuristic.
+    2. ``## MCP servers connected`` — one sub-block per server from
+       ``tools.mcp_tool.get_registered_tools_by_server``.  Server purpose
+       comes from ``MCP_SERVER_PURPOSES``; tool list is sorted.
+    3. ``## CLI tools available via terminal`` — hardcoded list.
+
+    Returns ``""`` if nothing to render (defensive; should not happen in
+    normal startup since built-ins are always populated).
+
+    Cache stability: byte-identical output for a fixed
+    ``(_servers, valid_tool_names, tool_schemas)`` triple — server keys,
+    MCP tool names, and built-in names are all sorted before emit, and the
+    ``MCP_SERVER_PURPOSES`` fallback (first tool's description) reads from
+    the post-sort list.  Required because the architecture doc forbids
+    "cache-breaking mutations" — drift here invalidates the prompt-cache
+    prefix on every gateway restart.
+    """
+    parts: list[str] = []
+
+    # Build a name → schema lookup once.
+    schema_by_name: "dict[str, dict]" = {}
+    if tool_schemas:
+        for s in tool_schemas:
+            fn = s.get("function") if isinstance(s, dict) else None
+            if not isinstance(fn, dict):
+                continue
+            n = fn.get("name")
+            if isinstance(n, str):
+                schema_by_name[n] = fn
+
+    # ── Section 1: Built-in tools ────────────────────────────────────
+    builtin_lines: list[str] = []
+    if valid_tool_names:
+        for name in sorted(valid_tool_names):
+            if name.startswith("mcp_"):
+                continue
+            if name in INTERNAL_TOOL_DENYLIST:
+                continue
+            fn = schema_by_name.get(name, {})
+            desc = (fn.get("description") or "").strip()
+            if not desc or desc.startswith("Internal:"):
+                continue
+            # Collapse multi-line descriptions into one line.
+            desc_one_line = " ".join(desc.split())
+            # Cap each entry so a verbose tool doesn't dominate the section.
+            if len(desc_one_line) > 200:
+                desc_one_line = desc_one_line[:197] + "..."
+            builtin_lines.append(f"- {name}: {desc_one_line}")
+    if builtin_lines:
+        parts.append("## Built-in tools\n" + "\n".join(builtin_lines))
+
+    # MCP servers connected
+    mcp_block_lines: list[str] = []
+    try:
+        from tools.mcp_tool import get_registered_tools_by_server
+        mcp_by_server = get_registered_tools_by_server()
+    except (ImportError, AttributeError) as exc:
+        # Drift between repo and runtime: P78 not re-applied after
+        # ``hermes update``, or upstream removed ``_registered_tool_names``.
+        # WARNING-level so production-INFO logs surface it (debug is
+        # invisible at prod log level and would silently empty the section).
+        logger.warning(
+            "MCP registry accessor unavailable for tool inventory "
+            "(P78 not applied or upstream drift?): %s", exc,
+        )
+        mcp_by_server = {}
+
+    for server_name in sorted(mcp_by_server.keys()):
+        tools = mcp_by_server[server_name]
+        if not tools:
+            continue
+        # Sort once; both the fallback header and the body iteration read
+        # from the sorted list so output bytes don't depend on registration
+        # insertion order (load-bearing for prompt-cache stability).
+        sorted_tools = sorted(tools, key=lambda t: t[0])
+        purpose = MCP_SERVER_PURPOSES.get(server_name, "")
+        if not purpose:
+            first_desc = " ".join((sorted_tools[0][1] or "").split())
+            purpose = (first_desc[:80] + "...") if len(first_desc) > 80 else first_desc
+        header = f"### {server_name}" + (f" — {purpose}" if purpose else "")
+        mcp_block_lines.append(header)
+        for tool_name, desc in sorted_tools:
+            d = " ".join((desc or "").split())
+            if len(d) > 200:
+                d = d[:197] + "..."
+            mcp_block_lines.append(f"- {tool_name}: {d}" if d else f"- {tool_name}")
+
+    if mcp_block_lines:
+        parts.append("## MCP servers connected\n" + "\n".join(mcp_block_lines))
+
+    # ── Section 3: CLI tools via terminal ─────────────────────────────
+    if CLI_TOOLS_VIA_TERMINAL:
+        cli_lines = [f"- {name}: {desc}" for name, desc in CLI_TOOLS_VIA_TERMINAL]
+        parts.append(
+            "## CLI tools available via terminal\n" + "\n".join(cli_lines)
+        )
+
+    if not parts:
+        return ""
+
+    body = "\n\n".join(parts)
+    return (
+        "<tool_inventory>\n"
+        "When asked about your capabilities, enumerate from this list; "
+        "do not search docs about yourself.\n"
+        "\n"
+        + body + "\n"
+        "</tool_inventory>"
+    )
+
+
