+def _count_pending_markers() -> int:
+    """P192/MOL-330: defensive observability — count pending markers at run
+    start so cron output always carries the backlog signal even if downstream
+    queries fail. Pre-P192 the sweep produced no signal when the LLM short-
+    circuited with [SILENT], leaving operators blind to existing backlog."""
+    try:
+        return sum(1 for _ in _MARKER_DIR.glob("maintenance-pending-*.json"))
+    except OSError:
+        return -1
 
