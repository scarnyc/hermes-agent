+# P149/MOL-499: timeout error message contract shared between tier dispatch
+# functions (_run_cc_deepseek, _run_cc_anthropic, _run_hermes_swarm) and the
+# classifier. Tier functions format their timeout error_text as
+# f"{_TIMEOUT_ERROR_PREFIX} {N}s"; the classifier uses startswith to detect.
+# Sharing the constant locks the contract across the call sites.
+_TIMEOUT_ERROR_PREFIX = "timeout after"
+
+# P149/MOL-499: per-tier retry classification.
+# Match against (error_text + " " + stderr_tail).lower() — substring search.
+# Transient: 5xx blips, connection drops, DNS hiccups. Retry once with no wait.
+# Patterns are HTTP-anchored or contextualized to avoid false positives from
+# port numbers (e.g., :5030), variable names (e.g., eof_handler), or path
+# components (e.g., /etc/dns/). When a stderr substring matches BOTH a
+# transient and a deterministic pattern (rare but possible), deterministic
+# wins — see _classify_tier_failure docstring for the tie-breaking rule.
+_TRANSIENT_PATTERNS = [  # P149/MOL-499
+    "connection reset", "connectionreseterror", "broken pipe",
+    "temporary failure", "unexpected eof", "eof received",
+    "http 503", "http 502", "http 504", "503 service",
+    "500 internal server", "gateway timeout",
+    "name resolution failed", "dns resolution failed",
+]
+
+# P149/MOL-499: authoritative (no retry) failure markers — auth, config, missing tools.
+# Retrying these wastes budget; surface the failure to the next tier instead.
+# Checked BEFORE _TRANSIENT_PATTERNS — when both bucket matches (e.g., DNS
+# permission-denied), deterministic wins (no retry) over transient (retry).
+_DETERMINISTIC_FAILURE_PATTERNS = [  # P149/MOL-499
+    "401 unauthorized", "403 forbidden",
+    "invalid api key", "invalid argument", "invalid_request",
+    "authentication failed", "authorization failed",
+    "permission denied",
+    "no such file", "command not found",
+    "missing required", "schema validation",
+    "key not available",  # P149 PR #170 review: api-key-missing path → deterministic, not unknown
+]
+
+# P149/MOL-499: retry policy per classification.
+# Tuple shape: (allow_retry, wait_before_retry_seconds).
+# `allow_retry` is binary in practice — the loop in _attempt_tier_with_retry
+# is hard-bounded to 2 iterations ("for attempt in (1, 2)"). A value of 1 means
+# "no retry" (the loop breaks after the first attempt's policy check); a value
+# of 2 means "retry once" (one extra call after the first failure). Larger
+# values have NO additional effect — the loop bound caps them. Field is named
+# "max_attempts" historically; semantically a 2-state flag.
+# Note: "timeout" → no retry because the timeout already burned the full
+# tier_timeout budget — retrying would burn another full window.
+# Note: "unknown" → no retry (conservative); unclassified failures may be
+# deterministic config issues we haven't catalogued yet.
+_RETRY_POLICY = {
+    "rate_limit":    (2, 60),
+    "transient":     (2,  0),
+    "deterministic": (1,  0),
+    "timeout":       (1,  0),
+    "unknown":       (1,  0),
+}
+
+# P149/MOL-499 PR #170 review: classification fallback when classifier returns
+# a value not in _RETRY_POLICY. Defensively conservative — no retry. Future
+# classifier outputs that aren't catalogued here will fall back instead of
+# raising KeyError.
+_DEFAULT_RETRY_POLICY = (1, 0)
+
