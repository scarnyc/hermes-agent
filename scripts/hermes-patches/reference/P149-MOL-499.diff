+def _classify_tier_failure(error_text: str, stderr_tail: str) -> str:
+    """P149/MOL-499: classify a tier failure for retry decisions.
+
+    Returns one of: 'rate_limit', 'timeout', 'deterministic', 'transient', 'unknown'.
+
+    Order matters (tie-breaking rules — when a stderr substring matches
+    multiple buckets, the earlier check wins):
+      1. timeout — already burned full tier_timeout, retry doubles the burn.
+         Checked via `error_text.startswith(_TIMEOUT_ERROR_PREFIX)` ONLY —
+         stderr_tail is not searched for timeout because partial output from
+         a timed-out subprocess may incidentally contain "timeout after" text
+         that isn't a structured timeout signal. Contract: tier dispatch
+         functions MUST format their timeout error_text as
+         f"{_TIMEOUT_ERROR_PREFIX} {N}s".
+      2. rate_limit — wait-then-retry policy. Wins over transient because
+         some rate-limit payloads include downstream 503s.
+      3. deterministic — auth/config (no retry, fall through). Wins over
+         transient when both match (e.g., "permission denied" on a DNS
+         config path matches both `permission denied` deterministic AND
+         could match a future broader DNS-related transient pattern).
+      4. transient — connection/5xx blips (immediate retry).
+      5. unknown — conservative (no retry).
+    """
+    err_low = (error_text or "").lower()
+    if err_low.startswith(_TIMEOUT_ERROR_PREFIX):
+        return "timeout"
+    combined = f"{err_low} {(stderr_tail or '').lower()}"
+    if not combined.strip():
+        return "unknown"
+    if any(p in combined for p in _RATE_LIMIT_PATTERNS):
+        return "rate_limit"
+    if any(p in combined for p in _DETERMINISTIC_FAILURE_PATTERNS):
+        return "deterministic"
+    if any(p in combined for p in _TRANSIENT_PATTERNS):
+        return "transient"
+    return "unknown"
+
+
+def _attempt_tier_with_retry(
+    tier_call,
+    tier_num: int,
+    phase_name: str,
+    phase_start: float,
+    phase_budget: int,
+    tier_timeout: int,
+) -> dict:
+    """P149/MOL-499: dispatch a tier with ≤2 attempts based on failure classification.
+
+    `tier_call` is a zero-arg callable that runs the tier and returns the
+    standard {success, output, tier, error, stderr_tail, rate_limited?} dict.
+
+    Phase-budget guard: skip retry if remaining < (retry_wait + tier_timeout).
+    DRY_RUN: log decision, skip `time.sleep(retry_wait)`. The tier call ITSELF
+    is still executed in DRY_RUN — only the inter-attempt sleep is suppressed.
+    Do not use DRY_RUN with live tier callables if retry attempts must be
+    suppressed.
+
+    Loop is hard-bounded at 2 attempts (`for attempt in (1, 2)`); `_RETRY_POLICY`
+    tuple values > 2 have no additional effect.
+
+    Logs every retry decision as JSONL `tier_retry_decision` for forensics.
+    On attempt-2 exhaustion (both attempts used) logs `exhausted_attempts`.
+    On uncaught exception from `tier_call()` logs `tier_attempt_exception`
+    + re-raises so state-recovery in main() still fires.
+    """
+    dry_run = DRY_RUN_FILE.exists()
+    last_result = None
+    for attempt in (1, 2):
+        # P149 PR #170 review: wrap tier_call to preserve JSONL forensics on
+        # unexpected exceptions. Re-raise so main()'s state-recovery fires.
+        try:
+            result = tier_call()
+        except Exception as exc:
+            _log_event("tier_attempt_exception",
+                       tier=tier_num, phase=phase_name, attempt=attempt,
+                       exc_type=type(exc).__name__,
+                       exc=str(exc)[:300])
+            raise
+        last_result = result
+        if result["success"]:
+            if attempt > 1:
+                _log_event("tier_retry_succeeded",
+                           tier=tier_num, phase=phase_name, attempt=attempt)
+            return result
+
+        if attempt >= 2:
+            # P149 PR #170 review: classify + log attempt-2 failures so the
+            # forensic record distinguishes "retry attempted, also failed"
+            # from "no retry attempted" via the `decision` field.
+            klass2 = _classify_tier_failure(
+                result.get("error", ""),
+                result.get("stderr_tail", ""),
+            )
+            _log_event("tier_retry_decision",
+                       tier=tier_num, phase=phase_name, attempt=attempt,
+                       classification=klass2, decision="exhausted_attempts")
+            break
 
+        klass = _classify_tier_failure(
+            result.get("error", ""),
+            result.get("stderr_tail", ""),
+        )
+        # P149 PR #170 review: defensive lookup. _RETRY_POLICY[klass] would
+        # KeyError + propagate to main()'s broad catch (losing forensics) if a
+        # future classifier output is added without updating the policy dict.
+        policy_entry = _RETRY_POLICY.get(klass, _DEFAULT_RETRY_POLICY)
+        if policy_entry is _DEFAULT_RETRY_POLICY and klass not in _RETRY_POLICY:
+            _log_event("tier_retry_decision",
+                       tier=tier_num, phase=phase_name, attempt=attempt,
+                       classification=klass,
+                       decision="unknown_class_fallback_no_retry")
+            break
+        max_attempts, retry_wait = policy_entry
+        if max_attempts <= 1:
+            _log_event("tier_retry_decision",
+                       tier=tier_num, phase=phase_name, attempt=attempt,
+                       classification=klass, decision="no_retry_by_policy")
+            break
 
+        phase_elapsed = time.monotonic() - phase_start
+        needed = retry_wait + tier_timeout
+        remaining = phase_budget - phase_elapsed
+        if needed > remaining:
+            _log_event("tier_retry_decision",
+                       tier=tier_num, phase=phase_name, attempt=attempt,
+                       classification=klass, decision="skipped_phase_budget",
+                       phase_elapsed_secs=round(phase_elapsed, 2),
+                       phase_budget=phase_budget,
+                       needed_secs=needed,
+                       remaining_secs=round(remaining, 2))
+            break
+
+        _log_event("tier_retry_decision",
+                   tier=tier_num, phase=phase_name, attempt=attempt,
+                   classification=klass, decision="retry",
+                   wait_seconds=retry_wait, dry_run=dry_run)
+        if retry_wait > 0 and not dry_run:
+            time.sleep(retry_wait)
+
+    return last_result
+
