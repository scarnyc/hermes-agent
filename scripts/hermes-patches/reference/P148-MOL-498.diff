+def _detect_orphan_claude_processes() -> list[dict]:
+    """P148/MOL-498: detect orphaned `claude -p` processes parented to launchd (PPID 1).
+
+    The 5/10 MOL-481 zombie (PID 87220, 12h+ runtime, `~/.local/bin/claude -p ...`)
+    proved cron's SIGKILL doesn't propagate to descendants. New spawn paths use
+    start_new_session=True + killpg, but pre-P148 orphans may still be running.
+    Log them so operators can kill manually.
+
+    Read-only; does NOT kill anything (the orphan might be doing legitimate work).
+
+    Tight match: full command must include `bin/claude` and start with `-p` args
+    pattern. Rejects false positives like `free-claude-code/.venv/bin/python`.
+    """
+    found: list[dict] = []
+    try:
+        r = subprocess.run(
+            ["ps", "-Ao", "pid=,ppid=,etime=,args="],
+            capture_output=True, text=True, timeout=5,
+        )
+    except (OSError, subprocess.TimeoutExpired):
+        return found
+    for line in r.stdout.splitlines():
+        parts = line.split(None, 3)
+        if len(parts) < 4:
+            continue
+        pid, ppid, etime, args = parts
+        if not pid.isdigit() or not ppid.isdigit():
+            continue
+        if int(ppid) != 1:
+            continue
+        # Match the actual claude binary spawn (~/.local/bin/claude or /opt/.../claude)
+        # AND require `-p ` flag (print mode = the cron path). Excludes interactive
+        # claude sessions (no -p) and unrelated processes with "claude" in the path.
+        if "bin/claude" not in args:
+            continue
+        if " -p " not in args and not args.endswith(" -p"):
+            continue
+        # Reject `python` processes whose path contains "claude" (e.g. free-claude-code).
+        first_token = args.split()[0] if args.split() else ""
+        if first_token.endswith("/python") or first_token.endswith("/python3"):
+            continue
+        found.append({"pid": int(pid), "ppid": int(ppid),
+                      "etime": etime, "args_head": args[:200]})
+    return found
 
 
+def _sigkill_recovery_sweep() -> int:
+    """P148/MOL-498: detect state files stuck `last_status=running` past 60 min and
+    flip to `failed` + increment attempt_count. Required because SIGKILL (e.g. cron's
+    3600s hard kill) bypasses main()'s exception handler entirely.
+
+    Also logs any orphaned `claude -p` processes parented to launchd (zombie detection).
+
+    Returns count of recovered state files.
+    """
+    # Orphan detection (log only; never auto-kill — operators decide).
+    orphans = _detect_orphan_claude_processes()
+    for o in orphans:
+        _log_event("orphan_claude_detected", pid=o["pid"], ppid=o["ppid"],
+                   etime=o["etime"], args_head=o["args_head"],
+                   note="parented to launchd; likely SIGKILL-orphaned from a prior cron tick. "
+                        "Manual investigation recommended.")
+    if orphans:
+        _log(f"WARN: {len(orphans)} orphaned claude process(es) detected — see "
+             f"symphony_bridge.log event=orphan_claude_detected. Manual review.")
+
+    # State-file recovery sweep.
+    if not STATE_DIR.exists():
+        return 0
+    recovered = 0
+    now = datetime.now(timezone.utc)
+    for sf in sorted(STATE_DIR.glob("MOL-*.json")):
+        try:
+            state = json.loads(sf.read_text())
+        except (json.JSONDecodeError, OSError):
+            continue
+        if state.get("last_status") != "running":
+            continue
+        last_ts = state.get("last_attempt_ts")
+        if not last_ts:
+            continue
+        try:
+            last_dt = datetime.fromisoformat(last_ts)
+            age = (now - last_dt).total_seconds()
+        except (ValueError, TypeError):
+            continue
+        # Within the 60-min window: legitimate in-flight, skip.
+        if age <= 3600:
+            continue
+        # Past 60-min: SIGKILL-recovered stale state.
+        prev_phase = state.get("last_checkpoint_phase", "unknown")
+        state["last_status"] = "failed"
+        state["attempt_count"] = state.get("attempt_count", 0) + 1
+        state["sigkill_recovered_at"] = _now_et_iso()
+        try:
+            tmp = sf.with_suffix(".tmp")
+            tmp.write_text(json.dumps(state, indent=2) + "\n")
+            os.replace(tmp, sf)
+        except OSError:
+            continue
+        _log_event("sigkill_recovery", key=state.get("key", sf.stem),
+                   last_checkpoint_phase=prev_phase,
+                   stale_minutes=int(age / 60),
+                   new_attempt_count=state["attempt_count"])
+        _log(f"sigkill_recovery: {state.get('key', sf.stem)} stale {int(age/60)}m at "
+             f"phase={prev_phase}; attempt_count -> {state['attempt_count']}")
+        recovered += 1
+    return recovered
+
