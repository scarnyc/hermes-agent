+def _kill_process_group(proc: subprocess.Popen) -> None:
+    """P148/MOL-498: kill the entire process group of `proc`.
+
+    Required because `proc.kill()` only signals the immediate child — but `claude -p`
+    spawns subprocesses that survive parent death and re-attach to launchd as orphans.
+    The 5/10 zombie (PID 87220, 12h+ runtime, MOL-481) was created exactly this way.
+
+    Pairs with `start_new_session=True` at Popen time so the child has its own pgid.
+    """
+    try:
+        pgid = os.getpgid(proc.pid)
+        os.killpg(pgid, signal.SIGTERM)
+        # Give the group 2s to exit gracefully, then SIGKILL.
+        try:
+            proc.wait(timeout=2)
+        except subprocess.TimeoutExpired:
+            os.killpg(pgid, signal.SIGKILL)
+    except (OSError, ProcessLookupError):
+        # Process group already gone — fall back to direct kill.
+        try:
+            proc.kill()
+        except OSError:
+            pass
+
