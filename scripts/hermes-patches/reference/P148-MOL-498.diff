+def _preflight_probe() -> None:
+    """P148/MOL-498: baseline parent-process reachability data point for api.deepseek.com.
+
+    NOT a gate (gate ships in Phase 2 / MOL-501). Answers 'can the parent process reach
+    DeepSeek?' which is independent of whether the `claude -p` child subprocess can —
+    child-process probe is Phase 2's job.
+    """
+    ds_key = _get_api_key("DEEPSEEK_API_KEY")
+    start = time.monotonic()
+    headers = []
+    if ds_key:
+        headers = ["-H", f"Authorization: Bearer {ds_key}"]
+    try:
+        r = subprocess.run(
+            ["curl", "--max-time", "5", "-sS", "-o", "/dev/null",
+             "-w", "%{http_code}", DEEPSEEK_ENDPOINT,
+             "-X", "POST", "-H", "Content-Type: application/json",
+             *headers, "-d", "{}"],
+            capture_output=True, text=True, timeout=8,
+        )
+        elapsed_ms = int((time.monotonic() - start) * 1000)
+        _log_event("preflight_probe", endpoint=DEEPSEEK_ENDPOINT,
+                   http_code=r.stdout.strip(), elapsed_ms=elapsed_ms,
+                   curl_stderr=_stderr_tail(r.stderr),
+                   key_available=bool(ds_key),
+                   probe_note="parent-process reachability baseline; not a gate")
+    except (OSError, subprocess.TimeoutExpired) as exc:
+        elapsed_ms = int((time.monotonic() - start) * 1000)
+        _log_event("preflight_probe", endpoint=DEEPSEEK_ENDPOINT,
+                   http_code=None, elapsed_ms=elapsed_ms,
+                   error=str(exc), key_available=bool(ds_key),
+                   probe_note="parent-process probe failed; tick proceeds")
+
