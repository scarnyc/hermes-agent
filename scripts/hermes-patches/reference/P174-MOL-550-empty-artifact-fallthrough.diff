+def _check_artifact_or_cascade(result: dict, artifact_path: "Path | None",
+                                phase_name: PhaseName, tier_num: int) -> bool:
+    """P174/MOL-550 F9: artifact-empty cascade gate. Returns True if the tier's
+    artifact is good (caller should return result); False if the artifact is
+    missing/empty (caller should fall through to next tier).
+
+    Iter 5 S6 failure (2026-05-12): Tier 1 subprocess exited subtype:success
+    via ExitPlanMode but plan_file was empty (P172 F7 wording trap caused
+    DeepSeek to fight Write tool instead of cleanly calling ExitPlanMode).
+    Bridge halted at phase level because phase_planner read the empty file
+    AFTER run_phase_with_fallback already returned — never cascaded to Tier 2.
+    F9 moves the artifact check inside the cascade.
+
+    artifact_path=None means the phase doesn't have a file artifact (skeptic
+    captures VERDICT in stdout; builder parses PR_NUM from stdout) — those
+    phases pass artifact_path=None (default) and skip the F9 check entirely.
+    """
+    if artifact_path is None:
+        return True  # No artifact contract — trust subprocess success
+    if not artifact_path.exists() or artifact_path.stat().st_size == 0:
+        size_bytes = artifact_path.stat().st_size if artifact_path.exists() else 0
+        _log_event("phase_empty_output_anomaly", phase=phase_name,
+                   tier=tier_num, path=str(artifact_path),
+                   size_bytes=size_bytes,
+                   reason="exit-0 but artifact missing/empty — cascading to next tier")
+        result["success"] = False
+        result["error"] = "empty_artifact_anomaly"
+        return False
+    return True
 
