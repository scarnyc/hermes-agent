+<?xml version="1.0" encoding="UTF-8"?>
+<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+<!--
+  Symphony v2 daemon — Phase 4c (P157/MOL-515).
+
+  Long-running process that owns its own loop over queue.db. Replaces
+  cron-as-driver. SIGKILL-at-3600s is no longer a thing because launchd
+  KeepAlive (with SuccessfulExit=false) auto-restarts on crash but does
+  NOT enforce a wall-clock kill.
+
+  Start the soak:
+    launchctl bootstrap gui/$UID ~/Library/LaunchAgents/ai.hermes.symphony-daemon.plist
+
+  Stop:
+    launchctl bootout gui/$UID/ai.hermes.symphony-daemon
+
+  Tail:
+    tail -f ~/.hermes/logs/symphony-daemon.log
+
+  Pause without unloading:
+    touch ~/.hermes/symphony/PAUSED   # daemon polls but does not poll the queue
+    rm    ~/.hermes/symphony/PAUSED   # resume
+
+  Observe-only:
+    touch ~/.hermes/symphony/DRY_RUN  # daemon polls but does not claim
+-->
+<plist version="1.0">
+<dict>
+    <key>Label</key>
+    <string>ai.hermes.symphony-daemon</string>
+
+    <key>ProgramArguments</key>
+    <array>
+        <string>/Users/wills_mac_mini/.hermes/scripts/envchain-wrapper.sh</string>
+        <string>/Users/wills_mac_mini/.hermes/hermes-agent/venv/bin/python</string>
+        <string>/Users/wills_mac_mini/.hermes/scripts/symphony_daemon.py</string>
+    </array>
+
+    <key>WorkingDirectory</key>
+    <string>/Users/wills_mac_mini/.hermes</string>
+
+    <key>EnvironmentVariables</key>
+    <dict>
+        <key>PATH</key>
+        <string>/Users/wills_mac_mini/.hermes/hermes-agent/venv/bin:/Users/wills_mac_mini/.hermes/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/wills_mac_mini/.local/bin</string>
+        <key>HERMES_HOME</key>
+        <string>/Users/wills_mac_mini/.hermes</string>
+        <key>VIRTUAL_ENV</key>
+        <string>/Users/wills_mac_mini/.hermes/hermes-agent/venv</string>
+        <key>PYTHONUNBUFFERED</key>
+        <string>1</string>
+    </dict>
+
+    <key>RunAtLoad</key>
+    <true/>
+
+    <key>KeepAlive</key>
+    <dict>
+        <key>SuccessfulExit</key>
+        <false/>
+    </dict>
+
+    <key>ThrottleInterval</key>
+    <integer>10</integer>
+
+    <key>ProcessType</key>
+    <string>Adaptive</string>
+
+    <key>LowPriorityIO</key>
+    <true/>
+
+    <key>Nice</key>
+    <integer>10</integer>
+
+    <key>SoftResourceLimits</key>
+    <dict>
+        <key>NumberOfFiles</key>
+        <integer>1024</integer>
+    </dict>
+
+    <key>StandardOutPath</key>
+    <string>/Users/wills_mac_mini/.hermes/logs/symphony-daemon.log</string>
+
+    <key>StandardErrorPath</key>
+    <string>/Users/wills_mac_mini/.hermes/logs/symphony-daemon.error.log</string>
+</dict>
+</plist>
