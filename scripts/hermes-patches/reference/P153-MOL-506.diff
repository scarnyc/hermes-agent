+    propagate to __main__'s broad catch, losing per-call attribution.
+
+    On failure: emit `state_write_failed` event tagged with `where`,
+    write stderr banner, return False. Caller decides whether to
+    continue (most paths continue — the dispatch_complete logging at
+    end of tick records the discrepancy via state-on-disk vs in-memory
+    state divergence).
+
+    Returns True on success.
+    """
+    try:
+        write_state(key, data)
+        return True
+    except (OSError, ValueError, TypeError) as exc:
+        _log_event("state_write_failed",
+                   key=key, where=where, exc_type=type(exc).__name__,
+                   exc=str(exc)[:200])
+        sys.stderr.write(
+            f"⚠️ {key}: state write failed at {where}: "
+            f"{type(exc).__name__}: {str(exc)[:200]}\n")
+        sys.stderr.flush()
+        return False
 
 
