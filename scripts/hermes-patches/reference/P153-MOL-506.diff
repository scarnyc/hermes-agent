+def _abort_budget_exhausted(key: str, state: dict, phase_name: PhaseName,
+                            tracker: "BudgetTracker") -> None:
+    """P153/MOL-506: clean-abort path when global wall-clock budget can't
+    cover the next phase. Writes state + log + stdout banner; caller breaks
+    the dispatch loop after this returns.
+
+    State shape: last_status="incomplete", abort_reason="global_budget_exhausted",
+    attempt_count += 1. The "incomplete" status + attempt_count semantics
+    match the existing phase-failure paths — SIGKILL recovery sweep and
+    max-attempts gate already handle "incomplete" correctly.
+
+    Ordering invariant: stderr banner fires FIRST so the abort stays
+    visible when write_state or _log_event subsequently fail (disk full,
+    sandbox-deny, JSONL log dir unwritable). The whole point of this
+    helper is to make SIGKILL's silent death loud — any error path that
+    hides it defeats P153's architectural purpose.
+    """
+    state["last_status"] = "incomplete"
+    state["abort_reason"] = "global_budget_exhausted"
+    state["attempt_count"] = state.get("attempt_count", 0) + 1
+    summary = tracker.to_summary()
+    banner = (f"⚠️ {key}: global budget exhausted before {phase_name} "
+              f"(remaining={summary['remaining_secs']:.0f}s)")
+    # Stderr first — last-resort channel that survives both write_state
+    # failure (state file unwritable) and _log_event failure (JSONL log
+    # dir unwritable). Cron output capture grabs stderr regardless.
+    sys.stderr.write(banner + "\n")
+    sys.stderr.flush()
+    # write_state can raise OSError (disk full, permission, sandbox-deny)
+    # or ValueError/TypeError (non-serializable state field). Catch + log
+    # so the abort still completes with a visible banner.
+    _safe_write_state(key, state, where=f"abort_budget_exhausted:{phase_name}")
+    _log(f"DISPATCH ABORTED (budget): {key} would-start={phase_name} "
+         f"remaining_secs={summary['remaining_secs']}")
+    _log_event("budget_exhausted_abort", key=key, phase=phase_name,
+               budget_summary=summary)
+    print(banner)
 
 
