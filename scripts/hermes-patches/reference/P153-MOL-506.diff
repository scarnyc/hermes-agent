+# ── BudgetTracker (P153/MOL-506) ───────────────────────────────────────────
+
+
+class BudgetTracker:
+    """Global wall-clock budget for a single ticket dispatch.
+
+    Construct via `BudgetTracker.start_now()` (or via `__init__` with an
+    explicit start_monotonic for state-file rehydration). The start time
+    is non-optional — the unarmed state is unrepresentable. Consulted
+    before each phase boundary in main() via can_start_phase, and at each
+    retry decision inside _attempt_tier_with_retry via remaining.
+    """
+
+    def __init__(self, budget_seconds: int, min_phase_budget: int,
+                 start_monotonic: float):
+        # Construction-time validation locks the invariants the type
+        # signature can't express. A negative budget would yield
+        # remaining()==0 forever; min_phase > budget would refuse every
+        # phase. Loud failure beats silent wedge.
+        if budget_seconds <= 0:
+            raise ValueError(
+                f"budget_seconds must be positive, got {budget_seconds}")
+        if not (0 <= min_phase_budget <= budget_seconds):
+            raise ValueError(
+                f"min_phase_budget={min_phase_budget} must be in "
+                f"[0, {budget_seconds}]")
+        self._budget = budget_seconds
+        self._min_phase = min_phase_budget
+        self._start_monotonic = start_monotonic
+
+    @classmethod
+    def start_now(cls, budget_seconds: int = _GLOBAL_BUDGET_SECONDS,
+                  min_phase_budget: int = _MIN_PHASE_BUDGET) -> "BudgetTracker":
+        """Primary production entry point: construct + arm in one step."""
+        return cls(budget_seconds, min_phase_budget, time.monotonic())
+
+    def elapsed(self) -> float:
+        return time.monotonic() - self._start_monotonic
+
+    def remaining(self) -> float:
+        return max(0.0, self._budget - self.elapsed())
+
+    def _effective_min_phase(self, phase: PhaseName) -> int:
+        """Phase-aware floor: a phase with a longer `_PHASE_TIMEOUTS`
+        entry (builder=1800, reviewer=900) needs that much remaining to
+        be worth starting. Otherwise builder kicks off with 400s left,
+        fails on the retry-budget guard, and gets attributed as "all
+        tiers failed" instead of the truer "budget exhausted".
+        """
+        return max(self._min_phase, _PHASE_TIMEOUTS.get(phase, 0))
+
+    def can_start_phase(self, phase: PhaseName) -> bool:
+        """True iff remaining() >= phase-aware floor."""
+        return self.remaining() >= self._effective_min_phase(phase)
+
+    def to_summary(self) -> dict:
+        """Two-decimal rounding is contract — JSONL log consumers
+        (`budget_summary` field in `budget_exhausted_abort`, banner
+        formatting) depend on the stable shape.
+        """
+        return {
+            "budget_secs": self._budget,
+            "elapsed_secs": round(self.elapsed(), 2),
+            "remaining_secs": round(self.remaining(), 2),
+        }
+
+    def __repr__(self) -> str:
+        return f"BudgetTracker({self.to_summary()})"
+
+
