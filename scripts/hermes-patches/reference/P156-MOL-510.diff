index 0000000..0000001
--- /dev/null
+++ b/.hermes/scripts/migrate_state_to_queue.py
@@ -0,0 +1,217 @@
+"""One-time migration: ~/.hermes/symphony/state/*.json → queue.db.
+PATCH: P156/MOL-510.
+
+Idempotent — uses INSERT OR IGNORE so re-running on a populated queue is
+a no-op for already-imported tickets. Existing queue rows are NEVER
+overwritten; the JSON files remain on disk as a rollback safety net
+until P158/MOL-513 (USE_DAEMON flag) explicitly retires them.
+
+Note on `running`: migrated `running` rows land in queue.db `running`
+state, but the existing P148 SIGKILL-recovery sweep operates on the
+JSON state files at `~/.hermes/symphony/state/*.json`, NOT on queue.db.
+Until P156/MOL-511 (daemon) or P158/MOL-513 (USE_DAEMON wire-up)
+extends recovery to queue.db, a migrated-then-stale `running` row will
+NOT auto-flip — operators must reset manually or wait for P156+.
+
+Mapping (json `last_status` → queue `state`):
+    unstarted                         → pending
+    succeeded                         → succeeded
+    running                           → running   (see note above)
+    failed                            → failed    (claimable for retry
+                                                    only after a retry-
+                                                    cadence policy flips
+                                                    back to pending —
+                                                    P157/MOL-512 territory)
+    incomplete + attempt_count >= _MAX_ATTEMPTS_LITERAL  → blocked
+    incomplete + attempt_count <  _MAX_ATTEMPTS_LITERAL  → pending
+    <anything else>                   → pending  (conservative;
+                                                   prints WARNING for
+                                                   operator visibility)
+
+DRY_RUN: set DRY_RUN=1 in the environment to print the proposed actions
+without touching the queue.
+
+Corruption handling: a JSON file that fails to decode (malformed, OSError
+during read, ValueError on int coercion of attempt_count, etc.) is
+renamed to `<key>.json.corrupt-<timestamp>` so the next run does not
+re-trip the same error AND the operator has a clear filesystem signal
+that the file needs attention.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sqlite3
+import sys
+from pathlib import Path
+
+# sibling-module import works when ~/.hermes/scripts/ is on sys.path
+sys.path.insert(0, str(Path(__file__).parent))
+import symphony_queue as sq  # noqa: E402
+
+_STATE_DIR = Path.home() / ".hermes" / "symphony" / "state"
+_QUEUE_DB = Path.home() / ".hermes" / "symphony" / "queue.db"
+
+# The threshold mirrors symphony_bridge.py's run_one skip-logic, which
+# uses a bare literal `if attempt_count >= 3:` (no exported constant).
+# A bump on either side requires updating BOTH this value AND the
+# bridge's run_one literal; the verifier asserts this value as a
+# load-bearing structural check.
+_MAX_ATTEMPTS_LITERAL = 3
+
+
+def _map_state(json_status: str, attempt_count: int) -> str:
+    if json_status == "succeeded":
+        return "succeeded"
+    if json_status == "running":
+        return "running"
+    if json_status == "failed":
+        return "failed"
+    if json_status == "incomplete":
+        if attempt_count >= _MAX_ATTEMPTS_LITERAL:
+            return "blocked"
+        return "pending"
+    if json_status == "unstarted":
+        return "pending"
+    print(
+        f"WARNING: unknown json_status={json_status!r}; defaulting to 'pending'",
+        file=sys.stderr,
+    )
+    return "pending"
+
+
+def _quarantine(path: Path) -> Path:
+    """Rename a corrupt JSON file with a `.corrupt-<ts>` suffix so the
+    next migration run does not trip on it again. Returns the new path."""
+    from datetime import datetime as _dt
+
+    suffix = _dt.now().strftime(".corrupt-%Y%m%d-%H%M%S")
+    new_path = path.with_name(path.name + suffix)
+    try:
+        path.rename(new_path)
+        print(f"  quarantined: {path.name} → {new_path.name}", file=sys.stderr)
+    except OSError as exc:
+        print(
+            f"  WARNING: could not quarantine {path.name}: {exc!r}",
+            file=sys.stderr,
+        )
+        return path
+    return new_path
+
+
+def migrate(
+    state_dir: Path = _STATE_DIR,
+    queue_db: Path = _QUEUE_DB,
+    *,
+    dry_run: bool = False,
+) -> dict[str, object]:
+    """Returns counts: {imported, skipped_existing, errors, error_files}."""
+    counts: dict[str, object] = {
+        "imported": 0,
+        "skipped_existing": 0,
+        "errors": 0,
+        "error_files": [],
+    }
+    if not state_dir.exists():
+        print(f"state_dir does not exist: {state_dir}", file=sys.stderr)
+        return counts
+
+    if not dry_run:
+        sq.init_queue(queue_db)
+
+    for path in sorted(state_dir.glob("*.json")):
+        try:
+            data = json.loads(path.read_text())
+            key = data.get("key") or path.stem
+            last_status = data.get("last_status", "unstarted")
+            attempt_count = int(data.get("attempt_count", 0) or 0)
+        except (OSError, json.JSONDecodeError, ValueError, TypeError) as exc:
+            print(f"ERROR reading {path.name}: {exc!r}", file=sys.stderr)
+            counts["errors"] = int(counts["errors"]) + 1  # type: ignore[assignment]
+            counts["error_files"].append(path.name)  # type: ignore[attr-defined]
+            if not dry_run:
+                _quarantine(path)
+            continue
+
+        target_state = _map_state(last_status, attempt_count)
+
+        if dry_run:
+            print(
+                f"DRY_RUN: {key:12s}  json={last_status:11s} attempts={attempt_count} "
+                f"→ queue state={target_state}"
+            )
+            continue
+
+        if sq.get_ticket(queue_db, key) is not None:
+            counts["skipped_existing"] = int(counts["skipped_existing"]) + 1  # type: ignore[assignment]
+            continue
+
+        sq.add_ticket(queue_db, key, initial_state=target_state)
+        # Backfill attempt_count + historical first_seen + last_outcome.
+        # add_ticket sets first_seen=now; we want to preserve the JSON's
+        # historical value where present, else fall back to a real
+        # timestamp (NEVER empty string — that would silently sort as
+        # oldest-possible in any future updated_at ordering).
+        historical_first_seen = data.get("first_seen") or sq._now_iso()
+        historical_updated_at = (
+            data.get("last_attempt_ts")
+            or data.get("first_seen")
+            or sq._now_iso()
+        )
+        with sqlite3.connect(queue_db, isolation_level=None) as conn:
+            cur = conn.execute(
+                """
+                UPDATE tickets
+                   SET attempt_count = ?,
+                       first_seen = ?,
+                       updated_at = ?,
+                       last_outcome = CASE
+                         WHEN ? = 'succeeded' THEN 'pass'
+                         WHEN ? IN ('failed','incomplete') THEN 'fail'
+                         ELSE NULL
+                       END
+                 WHERE key = ?
+                """,
+                (
+                    attempt_count,
+                    historical_first_seen,
+                    historical_updated_at,
+                    last_status,
+                    last_status,
+                    key,
+                ),
+            )
+            if cur.rowcount != 1:
+                print(
+                    f"  WARNING: backfill UPDATE for {key} matched "
+                    f"{cur.rowcount} rows (expected 1)",
+                    file=sys.stderr,
+                )
+        counts["imported"] = int(counts["imported"]) + 1  # type: ignore[assignment]
+        print(
+            f"imported: {key:12s}  json={last_status:11s} attempts={attempt_count} "
+            f"→ queue state={target_state}"
+        )
+
+    return counts
+
+
+def main(argv: list[str] | None = None) -> int:
+    dry_run = os.environ.get("DRY_RUN") == "1"
+    counts = migrate(dry_run=dry_run)
+    suffix = " (DRY_RUN)" if dry_run else ""
+    error_files = counts.get("error_files", [])
+    print(
+        f"\nDone{suffix}: imported={counts['imported']} "
+        f"skipped_existing={counts['skipped_existing']} errors={counts['errors']}"
+    )
+    if error_files:
+        print(f"  error_files (quarantined to *.corrupt-* if applicable):")
+        for f in error_files:
+            print(f"    - {f}")
+    return 1 if counts["errors"] else 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
