+# ── CC result-envelope parser (F10) ────────────────────────────────────────
+
+def _extract_cc_result_meta(stdout: str) -> dict:
+    """P175/MOL-550 F10: parse total_cost_usd / num_turns / subtype / is_error
+    from a `claude -p --output-format json` result envelope. Returns empty
+    dict on parse-fail so the caller can splice unconditionally — observability
+    fields land when stdout is a clean JSON envelope, silently no-op otherwise.
+
+    Iter 5 S6 dispatch (2026-05-12) couldn't recover the Tier 1 cost
+    post-hoc because the bridge logged `stdout_head=stdout[:500]` and the
+    `total_cost_usd` field lives past the 500-char boundary. F10 parses
+    the FULL stdout and surfaces the cost / turn-count / outcome subtype
+    as top-level fields on the tier_attempt event, with stdout_head
+    truncation retained for human spot-check.
+    """
+    if not stdout:
+        return {}
+    try:
+        env = json.loads(stdout.strip())
+    except (json.JSONDecodeError, ValueError):
+        return {}
+    if not isinstance(env, dict) or env.get("type") != "result":
+        return {}
+    return {
+        "cc_total_cost_usd": env.get("total_cost_usd"),
+        "cc_num_turns": env.get("num_turns"),
+        "cc_subtype": env.get("subtype"),
+        "cc_is_error": env.get("is_error"),
+    }
 
 
