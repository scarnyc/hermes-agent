+++ b/.hermes/scripts/symphony_telegram.py
@@ -0,0 +1,186 @@
+"""Symphony Telegram alerts — warning-class event notifier.
+PATCH: P177/MOL-520.
+
+Wires the symphony daemon to push plain-text alerts to Telegram when a
+ticket exits the dispatch pipeline in a non-success state. Throttled
+per-(key, event) via JSON map stored in tickets.last_telegram_alert_ts.
+
+Designed for the daemon path only — the cron-path (symphony_bridge run as
+script) keeps its existing print-warning lines as log-only signal.
+
+Fail-open: HTTP errors, missing env vars, malformed throttle JSON, and
+queue.db errors all log and return without raising. A broken alerter
+must NOT block the dispatch loop.
+
+Public API:
+    notify(event, key, detail, *, queue_db=None, throttle_seconds=3600)
+        → "sent" | "throttled" | "skipped:<reason>" | "error:<msg>"
+
+Event constants (daemon imports from here):
+    EVENT_BLOCKED            — ticket flipped to "blocked" (max attempts)
+    EVENT_FAILED             — terminal "failed" (incl. incomplete status)
+    EVENT_RUN_ONE_EXCEPTION  — bridge raised unhandled exception
+    EVENT_DAEMON_CRASH_SWEEP — startup sweep flipped a running row → failed
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sqlite3
+import sys
+import urllib.parse
+import urllib.request
+from datetime import datetime, timezone
+from pathlib import Path
+
+EVENT_BLOCKED = "blocked"
+EVENT_FAILED = "failed"
+EVENT_RUN_ONE_EXCEPTION = "run_one_exception"
+EVENT_DAEMON_CRASH_SWEEP = "daemon_crash_sweep"
+
+_DEFAULT_QUEUE_DB = Path.home() / ".hermes" / "symphony" / "queue.db"
+_JIRA_BROWSE_PREFIX = "https://deep-agent-one.atlassian.net/browse/"
+_LOG_PATH = "~/.hermes/logs/symphony_bridge.log"
+_HTTP_TIMEOUT_SECS = 15
+
+
+def _now_iso() -> str:
+    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def _parse_iso(s: str) -> datetime | None:
+    try:
+        # Accept both "Z" and "+00:00" suffixes.
+        if s.endswith("Z"):
+            s = s[:-1] + "+00:00"
+        return datetime.fromisoformat(s)
+    except (ValueError, AttributeError):
+        return None
+
+
+def _log(msg: str) -> None:
+    print(f"[{_now_iso()}] [symphony_telegram] {msg}", flush=True, file=sys.stderr)
+
+
+def _format(event: str, key: str, detail: str) -> str:
+    detail = (detail or "").strip()
+    detail_line = f" — {detail}" if detail else ""
+    return (
+        f"⚠️  {key}: {event}{detail_line}\n"
+        f"{_JIRA_BROWSE_PREFIX}{key}\n"
+        f"log: {_LOG_PATH}"
+    )
+
+
+def _load_alert_map(conn: sqlite3.Connection, key: str) -> dict[str, str]:
+    """Return the per-event ISO-timestamp map for this ticket.
+
+    Stored as JSON object in tickets.last_telegram_alert_ts (TEXT, nullable).
+    Malformed JSON or legacy single-string values are treated as empty —
+    we'd rather over-alert once than swallow events forever.
+    """
+    row = conn.execute(
+        "SELECT last_telegram_alert_ts FROM tickets WHERE key = ?", (key,)
+    ).fetchone()
+    if row is None:
+        return {}
+    raw = row[0] if isinstance(row, tuple) else row["last_telegram_alert_ts"]
+    if not raw:
+        return {}
+    try:
+        parsed = json.loads(raw)
+    except (json.JSONDecodeError, TypeError):
+        return {}
+    return parsed if isinstance(parsed, dict) else {}
+
+
+def _save_alert_map(conn: sqlite3.Connection, key: str, alert_map: dict[str, str]) -> None:
+    conn.execute(
+        "UPDATE tickets SET last_telegram_alert_ts = ? WHERE key = ?",
+        (json.dumps(alert_map, separators=(",", ":")), key),
+    )
+
+
+def _is_throttled(alert_map: dict[str, str], event: str, throttle_seconds: int) -> bool:
+    last_iso = alert_map.get(event)
+    if not last_iso:
+        return False
+    last_dt = _parse_iso(last_iso)
+    if last_dt is None:
+        return False
+    elapsed = (datetime.now(timezone.utc) - last_dt).total_seconds()
+    return elapsed < throttle_seconds
+
+
+def _send_telegram(text: str) -> tuple[bool, str]:
+    """Return (ok, status). Fail-open on any error."""
+    token = os.environ.get("TELEGRAM_BOT_TOKEN", "").strip()
+    chat_id = os.environ.get("TELEGRAM_CHAT_ID", "").strip()
+    if not token or not chat_id:
+        return False, "skipped:TELEGRAM_BOT_TOKEN_or_TELEGRAM_CHAT_ID_unset"
+    url = f"https://api.telegram.org/bot{token}/sendMessage"
+    payload = urllib.parse.urlencode({"chat_id": chat_id, "text": text}).encode()
+    try:
+        with urllib.request.urlopen(url, data=payload, timeout=_HTTP_TIMEOUT_SECS) as resp:
+            body = resp.read().decode("utf-8", errors="replace")
+            return (200 <= resp.status < 300), f"http {resp.status}: {body[:120]}"
+    except Exception as e:  # urllib raises many subclasses; one catch is enough here
+        return False, f"telegram_error: {e}"
+
+
+def notify(
+    event: str,
+    key: str,
+    detail: str = "",
+    *,
+    queue_db: str | Path | None = None,
+    throttle_seconds: int = 3600,
+) -> str:
+    """Send a Telegram alert for a warning-class symphony event.
+
+    Per-(key, event) throttling: if the same (key, event) pair fired within
+    `throttle_seconds`, this returns "throttled" without sending. Different
+    events for the same key alert independently.
+
+    Returns a short status string for logging. Never raises.
+    """
+    db_path = Path(queue_db) if queue_db else _DEFAULT_QUEUE_DB
+    if not db_path.exists():
+        _log(f"queue.db missing at {db_path} — sending without throttle check")
+        ok, status = _send_telegram(_format(event, key, detail))
+        return ("sent" if ok else f"error:{status}") + " (no-throttle)"
+
+    conn: sqlite3.Connection | None = None
+    try:
+        conn = sqlite3.connect(str(db_path), timeout=10.0, isolation_level=None)
+        conn.row_factory = sqlite3.Row
+        alert_map = _load_alert_map(conn, key)
+        if _is_throttled(alert_map, event, throttle_seconds):
+            return "throttled"
+        ok, status = _send_telegram(_format(event, key, detail))
+        if ok:
+            alert_map[event] = _now_iso()
+            _save_alert_map(conn, key, alert_map)
+            return "sent"
+        _log(f"send failed for {key}/{event}: {status}")
+        return f"error:{status}"
+    except sqlite3.Error as e:
+        _log(f"sqlite error for {key}/{event}: {e}")
+        # Still attempt to send so we don't lose the alert to a DB issue.
+        try:
+            ok, status = _send_telegram(_format(event, key, detail))
+            return ("sent" if ok else f"error:{status}") + " (db-error)"
+        except Exception as send_e:
+            _log(f"send raised after db-error for {key}/{event}: {send_e}")
+            return f"error:{send_e} (db-error)"
+    except Exception as e:
+        # Contract: notify() must NEVER raise. A broken alerter must not block the dispatch loop.
+        _log(f"unexpected error in notify for {key}/{event}: {e}")
+        return f"error:{e}"
+    finally:
+        if conn is not None:
+            try:
+                conn.close()
+            except Exception:
+                pass
